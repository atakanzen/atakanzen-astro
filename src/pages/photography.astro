---
import BaseLayout from "@layouts/BaseLayout.astro";
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

const files = import.meta.glob<{ default: ImageMetadata }>(
  "../assets/photographs/*.webp",
  { eager: true },
);

const photographs = [
  { file: "padar-island", alt: "Padar Island" },
  { file: "gili-air", alt: "Gili Air" },
  { file: "deers-in-padar", alt: "Deers in Padar" },
  { file: "moon", alt: "Moon" },
  { file: "samet-nangshe", alt: "Samet Nangshe" },
  { file: "paper-lantern", alt: "Paper Lantern" },
  { file: "rider-on-sea", alt: "Rider on Sea" },
].map((p) => ({
  ...p,
  src: files[`../assets/photographs/${p.file}.webp`].default,
}));

// Images render at full viewport width on mobile, ~one masonry column (~542px) on desktop.
const sizes = "(min-width: 768px) 542px, 100vw";
---

<BaseLayout
  title="Photography — Atakan Zengin"
  description="A collection of photographs from travels and everyday moments."
>
  <div class="max-w-6xl mx-auto px-6 py-16 md:py-20">
    <h1
      class="stagger-item font-display text-5xl md:text-6xl mb-14"
      style="animation-delay: 0.05s"
    >
      Photography
    </h1>

    <div class="columns-1 md:columns-2 gap-5">
      {
        photographs.map((photo, i) => (
          <div class="photo-item mb-5 break-inside-avoid">
            <Image
              src={photo.src}
              alt={photo.alt}
              sizes={sizes}
              loading={i < 4 ? "eager" : "lazy"}
              fetchpriority={i < 2 ? "high" : undefined}
              class="w-full rounded-sm hover:rounded-lg transition-all duration-500 hover:shadow-[0_0_40px_rgba(0,114,229,0.08)]"
            />
          </div>
        ))
      }
    </div>
  </div>

  <script>
    document.addEventListener("astro:page-load", () => {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("revealed");
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.1, rootMargin: "0px 0px -40px 0px" },
      );

      document
        .querySelectorAll(".photo-item")
        .forEach((el) => observer.observe(el));
    });
  </script>
</BaseLayout>
