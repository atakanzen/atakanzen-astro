---
import BaseLayout from "@layouts/BaseLayout.astro";
---

<BaseLayout title="404 — Atakan Zengin">
  <div
    class="h-[calc(100dvh-3.5rem)] flex flex-col items-center justify-center px-6 page-appear"
  >
    <p class="text-8xl md:text-9xl font-display text-(--border)">404</p>
    <p class="text-sm text-(--text-secondary) mt-4">This page doesn't exist.</p>
    <a
      href="/"
      class="text-sm text-(--accent) hover:underline mt-6 transition-colors duration-300"
    >
      &larr; go home
    </a>
  </div>
</BaseLayout>
